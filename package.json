{
  "name": "carrefour-api-automation",
  "version": "1.0.0",
  "description": "Automação de testes de API - Banco Carrefour (ServeRest)",
  "scripts": {
    "pretest": "node -e \"require('fs').mkdirSync('reports', { recursive: true })\"",
    "test": "newman run collections/ServeRest_Usuarios.postman_collection.json -e environments/serverest.postman_environment.json --reporters cli,junit,htmlextra --reporter-junit-export reports/junit-report.xml --reporter-htmlextra-export reports/html-report.html"
  },
  "devDependencies": {
    "newman": "^6.1.3",
    "newman-reporter-htmlextra": "^1.23.1"
  }
}
