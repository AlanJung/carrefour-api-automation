    {
      "name": "1. Setup - Criar Usuarios para Testes",
      "item": [
        {
          "name": "POST /usuarios - Criar usuario admin [201]",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const ts = Date.now();",
                  "pm.collectionVariables.set('email1', `admin_${ts}@automation.com`);",
                  "pm.collectionVariables.set('nome1', 'Usuario Admin Teste');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 - Usuario admin criado com sucesso', () => {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Resposta contem _id e mensagem de sucesso', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('_id');",
                  "  pm.expect(json._id).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.message).to.eql('Cadastro realizado com sucesso');",
                  "  pm.collectionVariables.set('userId1', json._id);",
                  "});",
                  "pm.test('Content-Type e application/json', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"{{nome1}}\",\n  \"email\": \"{{email1}}\",\n  \"password\": \"{{password1}}\",\n  \"administrador\": \"true\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios"]
            }
          }
        },
