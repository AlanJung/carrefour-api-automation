    {
      "name": "5. Listar Usuarios (GET /usuarios)",
      "item": [
        {
          "name": "GET /usuarios - Lista todos os usuarios [200]",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 - Lista retornada com sucesso', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Resposta contem quantidade e array usuarios', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('quantidade');",
                  "  pm.expect(json).to.have.property('usuarios');",
                  "  pm.expect(json.usuarios).to.be.an('array');",
                  "  pm.expect(json.quantidade).to.be.at.least(1);",
                  "  pm.expect(json.quantidade).to.eql(json.usuarios.length);",
                  "});",
                  "pm.test('Cada usuario possui campos obrigatorios', () => {",
                  "  const json = pm.response.json();",
                  "  json.usuarios.forEach(u => {",
                  "    pm.expect(u).to.have.all.keys('_id', 'nome', 'email', 'password', 'administrador');",
                  "  });",
                  "});",
                  "pm.test('Resposta segue o JSON Schema esperado', () => {",
                  "  const schema = {",
                  "    type: 'object',",
                  "    required: ['quantidade', 'usuarios'],",
                  "    properties: {",
                  "      quantidade: { type: 'integer', minimum: 0 },",
                  "      usuarios: {",
                  "        type: 'array',",
                  "        items: {",
                  "          type: 'object',",
                  "          required: ['_id', 'nome', 'email', 'password', 'administrador'],",
                  "          properties: {",
                  "            _id: { type: 'string' },",
                  "            nome: { type: 'string' },",
                  "            email: { type: 'string' },",
                  "            password: { type: 'string' },",
                  "            administrador: { type: 'string', enum: ['true', 'false'] }",
                  "          }",
                  "        }",
                  "      }",
                  "    }",
                  "  };",
                  "  pm.response.to.have.jsonSchema(schema);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios"]
            }
          }
        },
        {
          "name": "GET /usuarios?nome= - Filtro por nome [200]",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 - Filtro por nome retorna lista', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Retorna apenas usuarios com nome filtrado', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('quantidade');",
                  "  pm.expect(json.quantidade).to.be.at.least(1);",
                  "  const nome = pm.collectionVariables.get('nome1');",
                  "  json.usuarios.forEach(u => {",
                  "    pm.expect(u.nome).to.include(nome.split(' ')[0]);",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios?nome={{nome1}}",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios"],
              "query": [{ "key": "nome", "value": "{{nome1}}" }]
            }
          }
        }
      ]
    },
