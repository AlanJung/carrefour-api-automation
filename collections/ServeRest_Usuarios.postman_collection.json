      "item": [
        {
          "name": "POST /login - Sucesso [200]",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 - Login realizado com sucesso', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Resposta contem token JWT', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('authorization');",
                  "  pm.expect(json.authorization).to.be.a('string').and.include('Bearer ');",
                  "  pm.expect(json.message).to.eql('Login realizado com sucesso');",
                  "  pm.collectionVariables.set('token', json.authorization);",
                  "});",
                  "pm.test('Token salvo nas variaveis', () => {",
                  "  pm.expect(pm.collectionVariables.get('token')).to.not.be.empty;",
                  "});"
                ]
              }
